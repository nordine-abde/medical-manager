{
  "name": "medical-manager-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun run src/server.ts",
    "db:check": "bun run src/db/check-connection.ts",
    "db:migrate": "bun run src/db/run-migrations.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "bun test"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "better-auth": "^1.5.5",
    "elysia": "^1.4.16",
    "pg": "^8.20.0",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/pg": "^8.18.0",
    "bun-types": "^1.3.7",
    "typescript": "^5.9.3"
  }
}
